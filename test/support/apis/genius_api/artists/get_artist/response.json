":"p","children":["On 22 February 2021, Daft Punk ",{"tag":"a","attributes":{"href":"https://variety.com/2021/music/news/daft-punk-have-split-up-publicist-confirms-1234912186/","rel":"noopener nofollow"},"children":["announced"]}," their retirement through a video titled “Epilogue,” featuring footage from their 2004 film ",{"tag":"em","children":["Electroma"]}," and the orchestral version of ",{"tag":"a","attributes":{"href":"https://genius.com/Daft-punk-touch-lyrics","rel":"noopener"},"data":{"api_path":"/songs/151359"},"children":["“Touch”."]}," It marks an end to the incredible journey they had in influencing the world of music, with just four studio albums released over the course of 28 years."]},"",{"tag":"p","children":[{"tag":"a","attributes":{"href":"https://www.youtube.com/watch?v=DuDX6wNfjqc&feature=emb_title","rel":"noopener nofollow"},"children":["https://www.youtube.com/watch?v=DuDX6wNfjqc&feature=emb_title"]}]}]}},"facebook_name":"DaftPunk","header_image_url":"https://images.genius.com/65cd354bc41531872aca3356dc06eb83.1000x562x1.jpg","id":13585,"image_url":"https://images.genius.com/626f2887c30a9618cb1fbb383a16f8c1.1000x1000x1.png","instagram_name":"daftpunk","is_meme_verified":false,"is_verified":false,"name":"Daft Punk","social_links":{"twitter":"daftpunk","facebook":"DaftPunk","instagram":"daftpunk"},"translation_artist":false,"twitter_name":"daftpunk","url":"https://genius.com/artists/Daft-punk","current_user_metadata":{"permissions":["follow","view_activity_stream","view_contribution_opportunities","view_discography"],"excluded_permissions":["edit","edit_images","edit_names","edit_anything","merge","sort_artist_songs","edit_translation_artist","split","see_short_id"],"interactions":{"following":false}},"followers_count":1068,"artist_relationships":[],"description_annotation":{"_type":"referent","annotator_id":116340,"annotator_login":"palacelight","api_path":"/referents/6935907","classification":"accepted","fragment":"Daft Punk","id":6935907,"is_d