{
  "permissions": {
    "allow": [
      "Bash(dpkg -l)",
      "Bash(mix test:*)",
      "Bash(grep -E \"\\\\.ex$\")",
      "Bash(mix run --no-start -e ' *)",
      "Bash(mix run *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/remote/session-start.sh"}
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {"type": "command", "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in *.ex|*.exs) mix format \"$f\" ;; esac"}
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          // { "type": "command", "command": "git diff --quiet --name-only -- '*.ex' '*.exs' '.heex' || mix credo --strict", "timeout": 60},
          // { "type": "command", "command": "git diff --quiet --name-only -- '*.ex' '*.exs' '.heex' || mix test", "timeout": 60 }
        ]
      }
    ]
  }
}
