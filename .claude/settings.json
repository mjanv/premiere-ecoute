{
  "permissions": {
    "allow": [
      "Bash(dpkg -l)",
      "Bash(mix test:*)",
      "Bash(grep -E \"\\\\.ex$\")",
      "Bash(mix run --no-start -e ' *)",
      "Bash(mix run *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/remote/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/quality/format.sh"
          }
        ]
      }
    ]
  }
}
