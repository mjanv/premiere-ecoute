<div class="min-h-screen flex items-center justify-center bg-base-200 px-4">
  <.card variant="warning" class="max-w-md w-full p-8 space-y-2 text-center">
    <h1 class="text-lg font-semibold text-surface-primary">{@error}</h1>
    <p class="text-surface-muted">{@error_description}</p>
  </.card>
</div>
