<!DOCTYPE html>
<html lang="en" data-theme={get_user_theme(assigns)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Premiere Ecoute" suffix="">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/fonts/BricolageGrotesque/bricolage-grotesque.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%!-- React Flow CSS — produced by esbuild from the @xyflow/react CSS import in explore.js --%>
    <link phx-track-static rel="stylesheet" href={~p"/assets/js/explore.css"} />
    <%!-- explore.js must load before app.js to register window.__ExploreHooks --%>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/explore.js"}>
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js">
    </script>
    <script>
      // nonce={@script_src_nonce}>
           (() => {
             const setTheme = (theme) => {
               if (theme === "system") {
                 document.documentElement.removeAttribute("data-theme");
               } else {
                 document.documentElement.setAttribute("data-theme", theme);
               }
             };
             // Theme is now controlled by server-side user profile
             // Listen for theme updates from LiveView
             window.addEventListener("phx:set-theme", ({ detail: { theme } }) => setTheme(theme));
           })();
    </script>
  </head>
  <body class="premiere-ecoute-sandbox">
    {@inner_content}
  </body>
</html>
