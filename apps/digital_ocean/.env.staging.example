# Staging environment configuration
# Copy this to .env.staging at the project root and fill in values.
# Values that DIFFER from production are annotated below.

# Phoenix
PHX_HOST=staging.premiere-ecoute.fr
PHX_SERVER=true
PORT=4001
SECRET_KEY_BASE=<generate with: mix phx.gen.secret>
MIX_ENV=prod

# Database - isolated staging copy, created by staging-create.sh
POSTGRES_DATABASE=premiere_ecoute_staging
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=<same as production>
POSTGRES_HOSTNAME=localhost
# AIDEV-NOTE: Must match production key — staging DB is a clone of prod with encrypted columns
POSTGRES_ENCRYPTION_KEY=<same as production>

# Spotify API
# Add https://staging.premiere-ecoute.fr/auth/spotify/callback to your Spotify app's redirect URIs
SPOTIFY_CLIENT_ID=<same as production or separate staging app>
SPOTIFY_CLIENT_SECRET=<same as production or separate staging app>
SPOTIFY_REDIRECT_URI=https://staging.premiere-ecoute.fr/auth/spotify/callback

# Twitch API
# Add https://staging.premiere-ecoute.fr/auth/twitch/callback to your Twitch app's redirect URIs
TWITCH_CLIENT_ID=<same as production or separate staging app>
TWITCH_CLIENT_SECRET=<same as production or separate staging app>
TWITCH_REDIRECT_URI=https://staging.premiere-ecoute.fr/auth/twitch/callback
TWITCH_WEBHOOK_CALLBACK_URL=https://staging.premiere-ecoute.fr/webhooks/twitch
TWITCH_WEBHOOK_SECRET=<generate a new random secret for staging>
TWITCH_EXTENSION_SECRET=<same as production or a new one>

# Other APIs — leave empty for staging if not needed
DISCORD_BOT_TOKEN=
BUYMEACOFFEE_API_KEY=
YOUTUBE_DATA_API_V3_KEY=
GENIUS_ACCESS_TOKEN=
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
OPENAI_API_KEY=
MISTRAL_API_KEY=
RESEND_API_KEY=

# Admin panel
AUTH_USERNAME=
AUTH_PASSWORD=

# Observability — INTENTIONALLY DISABLED for staging
# Alloy only scrapes localhost:4000, so staging metrics never reach Grafana Cloud.
# Leaving GRAFANA_API_TOKEN empty prevents dashboard uploads and lifecycle annotations.
SENTRY_DSN=
GRAFANA_HOST=https://mjanv.grafana.net/
GRAFANA_API_TOKEN=
