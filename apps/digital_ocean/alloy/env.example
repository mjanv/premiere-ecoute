# AIDEV-NOTE: Environment variables for Grafana Alloy
# Copy this file to /etc/alloy/env and fill in your Grafana Cloud credentials
# The API key must have metrics:write and logs:write scopes (access policy: stack-724012-alloy-premiere-ecoute)

# Grafana Cloud Prometheus configuration
# Get these from: https://grafana.com/orgs/<your-org>/stacks
GRAFANA_CLOUD_PROMETHEUS_URL=https://prometheus-prod-XX-prod-XX-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROMETHEUS_USERNAME=123456
GRAFANA_CLOUD_API_KEY=your-api-key-here

# Grafana Cloud Loki configuration
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USERNAME=123456
