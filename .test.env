# Test environment variables for CI / Claude Code on the web.
# All API credentials are dummies — every external service is mocked in test.exs.
# Committed intentionally: these values grant no real access.

# Spotify (mocked in tests)
SPOTIFY_CLIENT_ID=test_spotify_client_id
SPOTIFY_CLIENT_SECRET=test_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:4002/auth/spotify/callback

# Twitch (mocked in tests)
TWITCH_CLIENT_ID=test_twitch_client_id
TWITCH_CLIENT_SECRET=test_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:4002/auth/twitch/callback
TWITCH_WEBHOOK_CALLBACK_URL=http://localhost:4002/webhooks/twitch
TWITCH_WEBHOOK_SECRET=test_webhook_secret
TWITCH_EXTENSION_SECRET=dGVzdF90d2l0Y2hfZXh0ZW5zaW9uX3NlY3JldA==

# Discord (mocked in tests)
DISCORD_BOT_TOKEN=test_discord_bot_token

# BuyMeACoffee (mocked in tests)
BUYMEACOFFEE_API_KEY=test_buymeacoffee_api_key

# Music metadata APIs (mocked in tests)
YOUTUBE_DATA_API_V3_KEY=test_youtube_key
GENIUS_ACCESS_TOKEN=test_genius_token
TIDAL_CLIENT_ID=test_tidal_client_id
TIDAL_CLIENT_SECRET=test_tidal_client_secret

# Mailer / AI (not exercised in tests)
RESEND_API_KEY=re_test_key
OPENAI_API_KEY=sk-test-openai-key
MISTRAL_API_KEY=test_mistral_key

# Monitoring (inactive in tests)
SENTRY_DSN=https://test@sentry.io/0

# Feature flags
AUTH_USERNAME=test_admin
AUTH_PASSWORD=test_password

# Database — local PostgreSQL started by the session hook
POSTGRES_HOSTNAME=localhost
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

# AES-256 key (32 zero bytes in base64, valid for Cloak.Ciphers.AES.GCM in tests)
POSTGRES_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
